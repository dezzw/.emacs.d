#!/usr/bin/env bash
# Update Emacs source inputs.
# Usage:
#   ./update              # Update both git and igc
#   ./update git          # Update only emacs-src-git
#   ./update igc          # Update only emacs-src-igc
set -euo pipefail

SCRIPTPATH="$( cd "$(dirname "$0")" ; pwd -P )"
cd "$SCRIPTPATH"

update_git() {
  echo "==> Updating emacs-src-git..."
  nix flake lock --update-input emacs-src-git
}

update_igc() {
  echo "==> Updating emacs-src-igc..."
  nix flake lock --update-input emacs-src-igc
}

if [ $# -eq 0 ]; then
  update_git
  update_igc
else
  case "$1" in
    git)     update_git ;;
    igc)     update_igc ;;
    *)       echo "Unknown target: $1"; echo "Usage: $0 [git|igc]"; exit 1 ;;
  esac
fi
